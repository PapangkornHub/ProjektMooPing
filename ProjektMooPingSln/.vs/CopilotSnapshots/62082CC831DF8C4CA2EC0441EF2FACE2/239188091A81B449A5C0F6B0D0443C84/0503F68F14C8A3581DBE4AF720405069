using System.Text.Json;
using System.Collections.ObjectModel;
using ProjektMooPing.Models;
using Location = ProjektMooPing.Models.Location;

namespace ProjektMooPing
{
	public partial class MainGamePage : ContentPage
	{
        public MainGamePage()
        {
            InitializeComponent();
            LoadGameData();

            MenuTab.IsVisible = true;
            EditTab.IsVisible = false;
            InvTab.IsVisible = false;
            LocTab.IsVisible = false;
            this.BindingContext = this;
        }

        public List<FoodItem> MyMenu { get; set; }
        private string _currentGameStateImage = "wall_rural.png";
        public string CurrentGameStateImage
        {
            get => _currentGameStateImage;
            set
            {
                _currentGameStateImage = value;
                OnPropertyChanged(nameof(CurrentGameStateImage));
            }
        }
        private async void StartCustomerAnimation(object sender, EventArgs e)
        {
            var btn = (Button)sender;
            btn.IsEnabled = false;

            int totalCustomers = 2;
            for (int i = 1; i <= totalCustomers; i++)
            {
                // Reset
                CustomerSprite.TranslationX = 600;
                CustomerSprite.Opacity = 1;

                // Walk
                await CustomerSprite.TranslateTo(80, 0, 2000, Easing.CubicOut);

                // Wait 2 Sec
                await Task.Delay(2000);

                // Walk Out 3 Sec
                await CustomerSprite.TranslateTo(-300, 0, 2000, Easing.CubicIn);

                // Delay
                await Task.Delay(1000);
            }
            await DisplayAlert("จบวัน!", "วันนี้ขายดีมากครับท่านผู้นำ (ลูกค้าเดินจากขวามาซ้ายเรียบร้อย)", "เย้!");
            btn.IsEnabled = true;
        }

        // Tab Menu
        private void OnMenuClicked(object sender, EventArgs e)
        {
            MenuTab.IsVisible = true;
            EditTab.IsVisible = false;
            InvTab.IsVisible = false;
            LocTab.IsVisible = false;
        }
        private void OnEditClicked(object sender, EventArgs e)
        {
            MenuTab.IsVisible = false;
            EditTab.IsVisible = true;
            InvTab.IsVisible = false;
            LocTab.IsVisible = false;
        }
        private void OnInvClicked(object sender, EventArgs e)
        {
            MenuTab.IsVisible = false;
            EditTab.IsVisible = false;
            InvTab.IsVisible = true;
            LocTab.IsVisible = false;
        }
        private void OnLocClicked(object sender, EventArgs e)
        {
            MenuTab.IsVisible = false;
            EditTab.IsVisible = false;
            InvTab.IsVisible = false;
            LocTab.IsVisible = true;
        }

        // Added handler for Relocate button in XAML
        private async void OnRelocateClicked(object sender, EventArgs e)
        {
            if (sender is Button btn)
            {
                // CommandParameter was set to the bound Location in XAML
                if (btn.CommandParameter is Location loc)
                {
                    CurrentLocation = loc;
                    OnPropertyChanged(nameof(CurrentLocation));
                    await DisplayAlert("Relocate", $"Relocated to {loc.LocName}", "OK");
                }
            }
        }

        public ObservableCollection<ProjektMooPing.Models.Location> AllLocations { get; set; } = new();
        public Location CurrentLocation { get; set; }
        public class MasterDataRoot
        {
            public List<ProjektMooPing.Models.Location> Locations { get; set; }
        }
        private async void LoadGameData()
        {
            try
            {
                // 1. เปิดไฟล์ MasterData.json จากในแอป (Resources/Raw)
                using var stream = await FileSystem.OpenAppPackageFileAsync("MasterData.json");
                using var reader = new StreamReader(stream);
                var contents = await reader.ReadToEndAsync();

                // 2. แปลง JSON เป็น Object (Deserialize)
                var data = JsonSerializer.Deserialize<MasterDataRoot>(contents, new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true // ป้องกันเรื่องตัวพิมพ์เล็ก-ใหญ่ใน JSON
                });

                if (data?.Locations != null)
                {
                    // 3. ยัดลง AllLocations เพื่อให้ CarouselView โชว์ผล
                    foreach (var loc in data.Locations)
                    {
                        // ตรวจสอบนามสกุลไฟล์ภาพ (ถ้าใน JSON ไม่มี .png ให้เติมตรงนี้)
                        if (!loc.ImagePath.EndsWith(".png"))
                            loc.ImagePath += ".png";

                        AllLocations.Add(loc);
                    }

                    // ตั้งค่าเริ่มต้นหลังจากโหลดเสร็จ
                    if (AllLocations.Count > 0)
                        CurrentLocation = AllLocations[0];
                }
            }
            catch (Exception ex)
            {
                await DisplayAlert("Error", "โหลดข้อมูลไม่สำเร็จ: " + ex.Message, "OK");
            }
        }
    }
}