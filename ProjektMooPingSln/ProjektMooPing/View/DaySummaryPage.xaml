<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:ProjektMooPing.Services"
             x:Class="ProjektMooPing.View.DaySummaryPage"
             BackgroundColor="#80000000">

    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
        <Border BackgroundColor="{StaticResource MooPingCream}"
                Stroke="{StaticResource MooPingDarkBrown}"
                StrokeThickness="3"
                WidthRequest="350" Padding="20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="15">

                <!-- หัวข้อ -->
                <Label x:Name="SummaryTitleLabel" Text=""
                       FontSize="22" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource MooPingDarkBrown}"/>

                <BoxView HeightRequest="1" Color="{StaticResource MooPingDarkBrown}" Opacity="0.3"/>

                <!-- รายการขาย -->
                <CollectionView ItemsSource="{Binding SalesDetails}" HeightRequest="130">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*, Auto, Auto" Padding="5">
                                <Label Text="{Binding MenuName}" TextColor="Black" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding Quantity, StringFormat=' {0} Unit(s)'}"
                                       Margin="10,0" TextColor="Gray" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="{Binding Revenue, StringFormat='{0}฿'}"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource MooPingDarkBrown}"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <BoxView HeightRequest="1" Color="{StaticResource MooPingDarkBrown}" Opacity="0.3"/>

                <!-- ยอดรวม -->
                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" RowSpacing="5">
                    <Label Text="{Binding LblTotalCost, Source={x:Static services:LocalizationService.Instance}}" TextColor="Gray"/>
                    <Label Grid.Column="1" Text="{Binding TotalCost, StringFormat='{0} ฿'}" TextColor="Brown"/>

                    <Label Grid.Row="1" Text="{Binding LblTotalIncome, Source={x:Static services:LocalizationService.Instance}}" TextColor="Gray"/>
                    <Label Grid.Row="1" Grid.Column="1"
                           Text="{Binding TotalRevenue, StringFormat='{0} ฿'}" TextColor="#76B041"/>

                    <Label Grid.Row="2" Text="{Binding LblTotalProfit, Source={x:Static services:LocalizationService.Instance}}"
                           FontAttributes="Bold" FontSize="18"
                           TextColor="{StaticResource MooPingDarkBrown}"/>
                    <Label Grid.Row="2" Grid.Column="1"
                           Text="{Binding TotalProfit, StringFormat='{0} ฿'}"
                           FontAttributes="Bold" FontSize="20" TextColor="#76B041"/>
                </Grid>

                <BoxView HeightRequest="1" Color="{StaticResource MooPingDarkBrown}" Opacity="0.3"/>

                <!-- Rating วันนี้ -->
                <Border BackgroundColor="#FFF8E1" Padding="15,12" StrokeThickness="1"
                        Stroke="#FFD700">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="8">

                        <!-- ดาว -->
                        <Label Text="{Binding StarDisplay}"
                               FontSize="30"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

                        <!-- คะแนนวันนี้ + รวม -->
                        <Grid ColumnDefinitions="*, *">
                            <Label x:Name="DailyPtsLabel" Text=""
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#76B041"
                                   HorizontalOptions="Center"/>
                            <Label Grid.Column="1" x:Name="TotalRatingLabel" Text=""
                                   FontSize="13"
                                   TextColor="#888888"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Breakdown แยก Factor -->
                        <BoxView HeightRequest="1" Color="#FFD700" Opacity="0.4"/>

                        <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto,Auto,Auto,Auto"
                              RowSpacing="4" ColumnSpacing="8">

                            <!-- Profit -->
                            <Label Text="💰" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding LblProfit, Source={x:Static services:LocalizationService.Instance}}"
                                   FontSize="13" TextColor="Gray" VerticalOptions="Center"/>
                            <Label Grid.Column="2"
                                   Text="{Binding ProfitScore, StringFormat='+{0}'}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="#76B041" VerticalOptions="Center"/>

                            <!-- Sales -->
                            <Label Grid.Row="1" Text="👥" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding LblSatisfy, Source={x:Static services:LocalizationService.Instance}}"
                                   FontSize="13" TextColor="Gray" VerticalOptions="Center"/>
                            <Label Grid.Row="1" Grid.Column="2"
                                   Text="{Binding SalesScore, StringFormat='+{0}'}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="#76B041" VerticalOptions="Center"/>

                            <!-- Quality -->
                            <Label Grid.Row="2" Text="🍢" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding LblQuality, Source={x:Static services:LocalizationService.Instance}}"
                                   FontSize="13" TextColor="Gray" VerticalOptions="Center"/>
                            <Label Grid.Row="2" Grid.Column="2"
                                   Text="{Binding QualityScore, StringFormat='+{0}'}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="#76B041" VerticalOptions="Center"/>

                            <!-- Stockout Penalty -->
                            <Label Grid.Row="3" Text="📦" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Row="3" Grid.Column="1" Text="{Binding LblStockout, Source={x:Static services:LocalizationService.Instance}}"
                                   FontSize="13" TextColor="Gray" VerticalOptions="Center"/>
                            <Label Grid.Row="3" Grid.Column="2"
                                   Text="{Binding StockoutPenalty, StringFormat='-{0}'}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="#CC3333" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ปุ่ม OK -->
                <Button Text="{Binding BtnOK, Source={x:Static services:LocalizationService.Instance}}" Clicked="OnCloseClicked"
                        BackgroundColor="#76B041" TextColor="White"
                        FontAttributes="Bold" CornerRadius="15"
                        HeightRequest="45" Margin="0,5,0,0"/>

            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>
