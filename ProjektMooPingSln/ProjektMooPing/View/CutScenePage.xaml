<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:ProjektMooPing.Services"
             x:Class="ProjektMooPing.View.CutScenePage"
             BackgroundColor="#CC000000">

    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
        <Border BackgroundColor="{StaticResource MooPingCream}"
                Stroke="{StaticResource MooPingDarkBrown}"
                StrokeThickness="3"
                Padding="25"
                WidthRequest="360">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="16">

                <!-- Title -->
                <Label x:Name="TitleLabel"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource MooPingDarkBrown}"/>

                <!-- Story Image -->
                <Border HorizontalOptions="Center"
                        WidthRequest="220"
                        HeightRequest="220"
                        BackgroundColor="White"
                        StrokeThickness="2"
                        Stroke="{StaticResource MooPingDarkBrown}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Image x:Name="StoryImage"
                           Aspect="AspectFit"
                           Margin="10"/>
                </Border>

                <!-- Text -->
                <Label x:Name="TextLabel"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="Black"
                       LineBreakMode="WordWrap"/>

                <!-- Page Indicator -->
                <Label x:Name="PageIndicatorLabel"
                       FontSize="11"
                       HorizontalOptions="Center"
                       TextColor="Gray"/>

                <!-- Action Button -->
                <Button x:Name="ActionBtn"
                        BackgroundColor="{StaticResource MooPingDarkBrown}"
                        TextColor="White"
                        CornerRadius="20"
                        HeightRequest="48"
                        FontAttributes="Bold"
                        Clicked="OnActionClicked"/>

            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>
