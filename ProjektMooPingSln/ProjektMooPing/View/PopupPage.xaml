<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjektMooPing.View.PopupPage"
             BackgroundColor="#80000000"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="30">
        <Border BackgroundColor="{StaticResource MooPingCream}"
                Stroke="{StaticResource MooPingDarkBrown}"
                StrokeThickness="3"
                WidthRequest="320"
                Padding="25">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="12">

                <!-- Icon -->
                <Label x:Name="IconLabel"
                       Text="⚠️"
                       FontSize="44"
                       HorizontalOptions="Center"/>

                <!-- Title -->
                <Label x:Name="TitleLabel"
                       Text=""
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource MooPingDarkBrown}"/>

                <!-- Message -->
                <Label x:Name="MessageLabel"
                       Text=""
                       FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="Gray"
                       Margin="0,4,0,8"/>

                <!-- Buttons -->
                <Grid x:Name="ButtonGrid"
                      ColumnDefinitions="*, *"
                      ColumnSpacing="10">

                    <Button x:Name="CancelButton"
                            Grid.Column="0"
                            Text="NO"
                            Clicked="OnCancelClicked"
                            BackgroundColor="{StaticResource MooPingMediumBrown}"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="15"
                            HeightRequest="45"/>

                    <Button x:Name="ConfirmButton"
                            Grid.Column="1"
                            Text="OK"
                            Clicked="OnConfirmClicked"
                            BackgroundColor="#76B041"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="15"
                            HeightRequest="45"/>
                </Grid>

            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>
